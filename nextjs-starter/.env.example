# IronixPay API Key (get yours at https://ironixpay.com)
# Sandbox keys start with sk_test_, production keys start with sk_live_
IRONIXPAY_SECRET_KEY=sk_test_your_secret_key_here

# IronixPay API Base URL
# Sandbox: https://sandbox.ironixpay.com (default)
# Production: https://api.ironixpay.com
IRONIXPAY_API_URL=https://sandbox.ironixpay.com

# Webhook secret for verifying webhook signatures (HMAC-SHA256)
IRONIXPAY_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Your app URL (used for success/cancel redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
