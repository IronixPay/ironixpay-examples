# ─── Telegram Bot ─────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# ─── IronixPay ────────────────────────────────────────────
# Get from https://app.ironixpay.com → Dashboard → API Keys
IRONIXPAY_SECRET_KEY=sk_test_your_key_here
IRONIXPAY_API_URL=https://sandbox.ironixpay.com
IRONIXPAY_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Server ───────────────────────────────────────────────
# Public URL for IronixPay webhooks (use ngrok for local dev)
WEBHOOK_PORT=3000
PUBLIC_URL=https://your-domain.com
